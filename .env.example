# Server Configuration
PORT=5011
NODE_ENV=development

# HTTPS Configuration (for production)
USE_HTTPS=false
SSL_KEY_PATH=/etc/ssl/private/server.key
SSL_CERT_PATH=/etc/ssl/certs/server.crt

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/otg_admin_panel

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Admin Configuration (used to seed the super-admin on first boot)
ADMIN_EMAIL=admin@otg.com
ADMIN_PASSWORD=OtgAdmin@2026

# AWS S3 Configuration
# Config Encryption Key
CONFIG_ENCRYPTION_KEY=your_config_encryption_key_here

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME=your_s3_bucket_name

# Email (SMTP) Configuration — used to email sellers on approval, etc.
# Works with any SMTP provider (AWS SES SMTP, Gmail app password, SendGrid, ...).
# If these are left unset, emails are skipped (approval still succeeds).
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=OTG <no-reply@otg.com>

# Link used in the "become a seller" approval email CTA (download seller app)
APP_DOWNLOAD_URL=https://play.google.com/store/apps/details?id=your.app.id
